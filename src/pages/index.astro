---
import Layout from '../layouts/Layouts.astro';

import Sidebar from '../components/Sidebar.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import TerminalWidget from '../components/TerminalWidget.astro';
import FooterBar from '../components/Footer.astro';
import { Image } from 'astro:assets';
import desktop1 from '../assets/desktop1.jpeg';
---

<Layout>

  <div class="app">

    <Sidebar />

    <main>

      <Hero />

      <Features />

      <section class="showcase dashboard-preview">
        <TerminalWidget />
        <div class="screenshots">
        <Image src={desktop1} alt="APX Desktop Preview" />
  		</div>
      </section>

      <FooterBar />

    </main>

  </div>

</Layout>

<style>
.app {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 1rem;

  min-height: 100vh;
}

main {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.showcase {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

@media (max-width: 900px) {
  .app {
    grid-template-columns: 1fr;
  }

  .showcase {
    grid-template-columns: 1fr;
  }
}
</style>